{
  "name": "che-triage",
  "version": "0.0.0",
  "author": "Florent Benoit",
  "description": "bot for che",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@actions/core": "^1.6.0",
    "@actions/github": "^6.0.1",
    "@octokit/webhooks": "^9.23.0",
    "axios": "^0.26.1",
    "fs-extra": "^10.0.1",
    "inversify": "^6.2.2",
    "moment": "^2.29.2",
    "mustache": "^4.2.0",
    "reflect-metadata": "^0.1.13",
    "semver": "^7.3.7",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@slack/web-api": "^7.8.0",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^27.4.1",
    "@types/mustache": "^4.2.5",
    "@types/node": "^17.0.24",
    "@types/reflect-metadata": "^0.1.0",
    "@types/semver": "^7.3.9",
    "@typescript-eslint/eslint-plugin": "^5.19.0",
    "@typescript-eslint/parser": "^5.19.0",
    "cpx": "^1.5.0",
    "eslint": "^8.13.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jest": "^26.1.4",
    "eslint-plugin-no-null": "^1.0.2",
    "import-sort-style-eslint": "^6.0.0",
    "jest": "^27.5.1",
    "prettier": "^2.6.2",
    "prettier-plugin-import-sort": "^0.0.7",
    "ts-jest": "^27.1.4",
    "typescript": "^4.6.3"
  },
  "scripts": {
    "build": "pnpm run lint && pnpm run test && pnpm run compile",
    "compile": "tsc --project . && cpx './src/template/*.md' './dist/template' --clean",
    "format": "prettier --write **/*.ts **/**/*.ts package.json tests/_data/**/*.* tests/_data/**/**/*.*",
    "format-check": "prettier --check **/*.ts **/**/*.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/dist"
    ],
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "prettier": {
    "printWidth": 140,
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "importSort": {
    ".ts": {
      "style": "eslint",
      "parser": "typescript"
    }
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
}
